generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============== USER & AUTH ==============

model User {
  id        String   @id @default(uuid())
  phone     String   @unique
  name      String?
  email     String?
  role      String   @default("CUSTOMER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
  cart      Cart?

  @@map("users")
}

model Otp {
  id        String   @id @default(uuid())
  phone     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, createdAt])
  @@map("otps")
}

// ============== MENU ==============

model Category {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  description String?
  image       String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  items       MenuItem[]

  @@map("categories")
}

model MenuItem {
  id          String      @id @default(uuid())
  name        String
  slug        String      @unique
  description String?
  price       Decimal
  image       String?
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  isAvailable Boolean     @default(true)
  isVeg       Boolean     @default(true)
  prepTime    Int?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  cartItems   CartItem[]
  orderItems  OrderItem[]

  @@map("menu_items")
}

// ============== CART ==============

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("carts")
}

model CartItem {
  id         String   @id @default(uuid())
  cartId     String
  cart       Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  quantity   Int      @default(1)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([cartId, menuItemId])
  @@map("cart_items")
}

// ============== ORDERS ==============

model Order {
  id                   String       @id @default(uuid())
  orderNumber          String       @unique
  userId               String
  user                 User         @relation(fields: [userId], references: [id])
  items                OrderItem[]
  status               String       @default("PENDING")
  subtotal             Decimal
  gst                  Decimal      @default(0)
  deliveryFee          Decimal      @default(0)
  discount             Decimal      @default(0)
  couponCode           String?
  total                Decimal
  deliveryAddress       String?
  paymentId            String?
  paymentStatus        String       @default("PENDING")
  notes                String?
  customerPhone        String?
  customerName         String?
  estimatedTime        Int?
  deliveryPartner      String?
  deliveryPartnerPhone String?
  deliveryPartnerName  String?
  orderType            String       @default("DELIVERY")
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  completedAt          DateTime?

  @@map("orders")
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  quantity   Int
  price      Decimal
  total      Decimal
  createdAt  DateTime @default(now())

  @@map("order_items")
}

// ============== COUPONS ==============

model Coupon {
  id            String   @id @default(uuid())
  code          String   @unique
  description   String?
  discountType  String
  discountValue Decimal
  minOrderValue Decimal?
  maxDiscount   Decimal?
  usageLimit    Int?
  usedCount     Int      @default(0)
  startsAt      DateTime
  expiresAt     DateTime
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("coupons")
}

// ============== PAYMENTS ==============

model Payment {
  id          String   @id @default(uuid())
  orderId     String   @unique
  razorpayId  String   @unique
  amount      Decimal
  currency    String   @default("INR")
  status      String
  method      String?
  createdAt   DateTime @default(now())
  webhookData String?

  @@map("payments")
}

// ============== CONTACT ==============

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

// ============== ADMIN AUDIT LOG ==============

model AdminLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String
  entity    String
  entityId  String
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  @@map("admin_logs")
}
