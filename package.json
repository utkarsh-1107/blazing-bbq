{
  "name": "blazing-bbq",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/server",
    "apps/client",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --workspace=apps/server",
    "dev:client": "npm run dev --workspace=apps/client",
    "build": "npm run build --workspaces",
    "build:server": "npm run build --workspace=apps/server",
    "build:client": "npm run build --workspace=apps/client",
    "prisma:generate": "prisma generate --schema prisma/schema.sqlite.prisma",
    "prisma:generate:prod": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:push": "prisma db push --schema prisma/schema.sqlite.prisma",
    "prisma:push:prod": "prisma db push --schema prisma/schema.prisma",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
